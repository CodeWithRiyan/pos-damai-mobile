{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "android": {
        "image": "latest",
        "buildType": "apk"
      },
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.parallel=true -Dorg.gradle.daemon=false -Dorg.gradle.jvmargs=-Xmx4g",
        "KOTLIN_INCREMENTAL": "true"
      }
    },
    "dev": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "dev",
      "env": {
        "APP_ENV": "dev",
        "EXPO_PUBLIC_API_URL": "https://api-dev-pos-damai.riyansolusi.com"
      }
    },
    "sit": {
      "extends": "base",
      "distribution": "internal",
      "channel": "sit",
      "env": {
        "APP_ENV": "sit",
        "EXPO_PUBLIC_API_URL": "https://api-sit-pos-damai.riyansolusi.com"
      }
    },
    "demo": {
      "extends": "base",
      "distribution": "internal",
      "channel": "demo",
      "env": {
        "APP_ENV": "demo",
        "EXPO_PUBLIC_API_URL": "https://api-demo-pos-damai.riyansolusi.com"
      }
    },
    "prod": {
      "extends": "base",
      "autoIncrement": true,
      "channel": "prod",
      "env": {
        "APP_ENV": "prod",
        "EXPO_PUBLIC_API_URL": "https://api-pos-damai.riyansolusi.com"
      }
    }
  }
}
